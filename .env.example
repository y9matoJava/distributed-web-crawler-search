# Environment Variables Example
# ВНИМАНИЕ: На сервере скопируйте этот файл в .env и измените пароли!

# PostgreSQL
POSTGRES_DB=crawler
POSTGRES_USER=crawler_user
POSTGRES_PASSWORD=change_this_super_secret_password

# RabbitMQ
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change_this_super_secret_rabbitmq_password

# Elasticsearch 
# (В продакшене Elasticsearch должен быть защищен паролем, но для 
# начального запуска мы используем закрытую Docker-сеть)
ELASTICSEARCH_JAVA_OPTS=-Xms1g -Xmx1g

# Spring Boot
SPRING_PROFILES_ACTIVE=prod
